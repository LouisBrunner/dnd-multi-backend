{
  "$schema": "https://json.schemastore.org/package.json",
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "dnd-core": "catalog:",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dnd": "catalog:",
    "react-dnd-html5-backend": "catalog:",
    "react-dnd-test-backend": "^16.0.1",
    "react-dnd-test-utils": "^16.0.1",
    "react-dnd-touch-backend": "catalog:",
    "react-dom": "^19.2.7",
    "semver": "^7.8.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/LouisBrunner"
  },
  "license": "MIT",
  "name": "meta",
  "private": true,
  "scripts": {
    "all": "bun run clean && bun run build && bun run vet && bun run test",
    "build": "bun run build:esm && bun run build:types",
    "build:all": "bun run build && bun run build:examples",
    "build:esm": "bun run scripts/build.ts",
    "build:examples": "vite build",
    "build:types": "bun run --filter '*' build:types",
    "clean": "rm -rf packages/*/dist examples/*.js examples/dist coverage",
    "format:fix": "bunx @biomejs/biome check --write .",
    "format:fix:internal": "bunx @biomejs/biome format --write",
    "prepublishOnly": "bun run all",
    "publish": "bun run scripts/publish.ts",
    "start": "vite",
    "start:dev": "NODE_ENV=development bun run start",
    "test": "bun test --isolate",
    "test:ci": "bun run test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "vet": "bun run typecheck && bunx @biomejs/biome check",
    "vet:ci": "bun run typecheck && bunx @biomejs/biome ci"
  },
  "type": "module",
  "workspaces": {
    "catalog": {
      "dnd-core": "^16.0.1",
      "react": "^16.14.0 || ^17.0.2 || ^18.0.0 || ^19.0.0",
      "react-dnd": "^16.0.1",
      "react-dnd-html5-backend": "^16.0.1",
      "react-dnd-touch-backend": "^16.0.1",
      "react-dom": "^16.14.0 || ^17.0.2 || ^18.0.0 || ^19.0.0"
    },
    "packages": [
      "./packages/*"
    ]
  }
}
