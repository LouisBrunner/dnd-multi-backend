{
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "dnd-core": "^16.0.1",
    "react": "^19.2.7",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dnd-test-backend": "^16.0.1",
    "react-dnd-test-utils": "^16.0.1",
    "react-dnd-touch-backend": "^16.0.1",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/LouisBrunner"
  },
  "license": "MIT",
  "name": "meta",
  "private": true,
  "scripts": {
    "build": "bun run build:esm && bun run build:types",
    "build:all": "bun run build && bun run build:examples",
    "build:esm": "go run ./cmd/bundler",
    "build:examples": "go run ./cmd/bundler -mode examples",
    "build:types": "bun run --filter '*' build:types",
    "clean": "rm -rf packages/*/dist examples/*.js coverage",
    "format:fix": "bunx @biomejs/biome check --write .",
    "prepare": "bun run clean && bun run build && bun run vet && bun run test",
    "publish": "bun run prepare && go run ./cmd/publish",
    "start": "go run ./cmd/bundler -mode dev",
    "start:dev": "NODE_ENV=development bun run start",
    "test": "bun test",
    "test:ci": "bun run test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "vet": "bun run typecheck && bunx @biomejs/biome check",
    "vet:ci": "bun run typecheck && bunx @biomejs/biome ci"
  },
  "type": "module",
  "workspaces": [
    "./packages/*"
  ]
}
